# Supabase — frontend
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App
VITE_APP_URL=http://localhost:5173

# AI Provider — Edge Functions (set in Supabase project secrets, not in .env)
# ROB-05: Correct env var name is GOOGLE_AI_API_KEY (not GOOGLE_GEMINI_API_KEY)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS — Edge Functions (SEC-01)
# Comma-separated list of allowed origins in production.
# Omit or leave empty to allow all origins (local dev only).
# Example: ALLOWED_ORIGINS=https://app.operia.io,https://staging.operia.io
ALLOWED_ORIGINS=
