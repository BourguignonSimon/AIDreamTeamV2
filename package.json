    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "supabase": "^1.148.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
